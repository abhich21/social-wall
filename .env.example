# ------------------------------
# Deployment (Docker Compose)
# ------------------------------
APP_DOMAIN=socialwall.2209.in
GITHUB_REPOSITORY=abhich21/social-wall
APP_IMAGE_TAG=latest
REMBG_IMAGE_TAG=latest

# ------------------------------
# App config
# ------------------------------
NODE_ENV=production
PORT=3001
JWT_SECRET=replace_with_long_random_secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_strong_password

# Docker mode: app calls separate rembg container
REMBG_MODE=external
REMBG_URL=http://social-wall-rembg:5000
